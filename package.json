{
  "name": "xtechman-miniapp",
  "version": "1.0.0",
  "description": "XTechMan 实用工具小程序",
  "scripts": {
    "test": "jest && eslint pages/**/*.wxml",
    "test:watch": "jest --watch"
  },
  "devDependencies": {
    "@wxml/parser": "^0.4.0",
    "eslint-plugin-wxml": "^0.8.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "miniprogram-simulate": "^1.2.5"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testMatch": [
      "**/*.test.js"
    ],
    "snapshotSerializers": [
      "miniprogram-simulate/jest-snapshot-plugin"
    ]
  },
  "dependencies": {
    "lunar-javascript": "^1.7.7"
  }
}
