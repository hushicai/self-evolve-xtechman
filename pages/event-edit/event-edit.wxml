<!-- pages/event-edit/event-edit.wxml -->
<!-- 运势日历编辑页面 - 星座运势主题 -->

<view class="edit-page">
  <!-- 日期 -->
  <view class="date-row">
    <text class="date-label">日期</text>
    <text class="date-value">{{date}}</text>
  </view>

  <!-- 时间选择 -->
  <view class="time-row">
    <text class="time-label">时间</text>
    <picker mode="time" value="{{time}}" bindchange="onTimeChange">
      <view class="time-picker">
        <text class="time-value">{{time || '选择时间'}}</text>
      </view>
    </picker>
  </view>

  <!-- 标题输入 -->
  <view class="input-row">
    <input 
      class="title-input" 
      placeholder="记录今天的运势..."
      value="{{title}}"
      bindinput="onTitleInput"
    />
  </view>

  <!-- 类型选择 - 2x2 网格布局 -->
  <view class="type-section">
    <text class="type-title">选择类型</text>
    <view class="type-grid">
      <view 
        wx:for="{{types}}" 
        wx:key="value"
        class="type-card {{type === item.value ? 'active' : ''}}"
        style="--card-color: {{item.color}}"
        data-value="{{item.value}}"
        bindtap="onTypeSelect"
      >
        <text class="type-icon">{{item.icon}}</text>
        <text class="type-label">{{item.label}}</text>
      </view>
    </view>
  </view>

  <!-- 按钮 -->
  <view class="btn-row">
    <button class="save-btn" style="background-color: {{color}}" bindtap="onSave">保存</button>
    <button wx:if="{{eventId}}" class="delete-btn" bindtap="onDelete">删除</button>
  </view>
</view>
