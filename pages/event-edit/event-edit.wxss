/* pages/event-edit/event-edit.wxss */
/* 事件编辑页面 - cc-ui 简洁风格 */

.edit-page {
  padding: 24rpx;
}

/* 日期行 */
.date-row {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  display: flex;
  justify-content: space-between;
}

.date-label {
  color: #999;
}

.date-value {
  color: #5677fc;
  font-weight: 500;
}

/* 时间行 */
.time-row {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  display: flex;
  justify-content: space-between;
}

.time-label {
  color: #999;
}

.time-picker {
  display: flex;
  align-items: center;
}

.time-value {
  color: #5677fc;
  font-weight: 500;
}

/* 输入行 */
.input-row {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.title-input {
  width: 100%;
  font-size: 32rpx;
}

/* 类型行 */
.type-row {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.type-label {
  display: block;
  color: #999;
  margin-bottom: 16rpx;
}

.type-list {
  display: flex;
  gap: 16rpx;
}

.type-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx;
  border: 2rpx solid #f0f0f0;
  border-radius: 8rpx;
}

.type-item.active {
  border-width: 2rpx;
}

.type-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

/* 按钮 */
.btn-row {
  display: flex;
  gap: 24rpx;
}

.save-btn {
  flex: 1;
  background-color: #5677fc;
  color: #ffffff;
  border-radius: 16rpx;
}

.delete-btn {
  flex: 1;
  background-color: #f44336;
  color: #ffffff;
  border-radius: 16rpx;
}