/* pages/event-edit/event-edit.wxss */
/* 运势日历编辑页面 - 星座运势主题 */

.edit-page {
  padding: 24rpx;
}

/* 日期行 */
.date-row {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  display: flex;
  justify-content: space-between;
}

.date-label {
  color: #999;
}

.date-value {
  color: #9333ea;
  font-weight: 500;
}

/* 时间行 */
.time-row {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  display: flex;
  justify-content: space-between;
}

.time-label {
  color: #999;
}

.time-picker {
  display: flex;
  align-items: center;
}

.time-value {
  color: #9333ea;
  font-weight: 500;
}

/* 输入行 */
.input-row {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.title-input {
  width: 100%;
  font-size: 32rpx;
}

/* 类型选择区 */
.type-section {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.type-title {
  display: block;
  color: #999;
  margin-bottom: 20rpx;
  font-size: 28rpx;
}

/* 类型网格 - 2x2 布局 */
.type-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.type-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 32rpx 16rpx;
  background-color: #fafafa;
  border: 2rpx solid transparent;
  border-radius: 16rpx;
  transition: all 0.2s ease;
}

.type-card.active {
  border-color: var(--card-color);
  background-color: color-mix(in srgb, var(--card-color) 8%, white);
}

.type-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.type-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.type-card.active .type-label {
  color: var(--card-color);
}

/* 按钮 */
.btn-row {
  display: flex;
  gap: 24rpx;
}

.save-btn {
  flex: 1;
  color: #ffffff;
  border-radius: 16rpx;
  font-weight: 500;
}

.delete-btn {
  flex: 1;
  background-color: #f5f5f5;
  color: #666;
  border-radius: 16rpx;
}
