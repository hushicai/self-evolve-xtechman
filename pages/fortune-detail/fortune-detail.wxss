/* pages/fortune-detail/fortune-detail.wxss */
/* 运势详情页 - 星座运势主题，卡片式布局 */

.detail-page {
  min-height: 100vh;
  background-color: #f8f9fa;
  padding: 24rpx;
}

/* 顶部日期 */
.header {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.date {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
}

.weekday {
  font-size: 28rpx;
  color: #666;
}

/* 通用卡片样式 */
.fortune-card,
.zodiac-card,
.lucky-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

/* 运势概览卡片 */
.main-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.fortune-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.fortune-title {
  font-size: 36rpx;
  font-weight: 600;
}

.fortune-score {
  display: flex;
  align-items: baseline;
}

.score-value {
  font-size: 56rpx;
  font-weight: 700;
}

.score-max {
  font-size: 24rpx;
  opacity: 0.8;
}

.fortune-bar {
  height: 12rpx;
  background-color: rgba(255, 255, 255, 0.3);
  border-radius: 6rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
}

.fortune-bar-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

.fortune-desc {
  font-size: 28rpx;
  opacity: 0.95;
}

/* 星座卡片 */
.zodiac-card {
  border-left: 6rpx solid #666;
}

.zodiac-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 28rpx;
}

.zodiac-icon {
  font-size: 72rpx;
}

.zodiac-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.zodiac-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.zodiac-element {
  font-size: 24rpx;
  color: #999;
}

/* 各方面运势 */
.aspects {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.aspect-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.aspect-name {
  width: 80rpx;
  font-size: 26rpx;
  color: #666;
}

.aspect-bar {
  flex: 1;
  height: 16rpx;
  background-color: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
}

.aspect-fill {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.5s ease;
}

.aspect-score {
  width: 60rpx;
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  text-align: right;
}

/* 温馨提示 */
.zodiac-tips {
  display: flex;
  gap: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.tip {
  flex: 1;
  font-size: 24rpx;
  color: #666;
  text-align: center;
  padding: 12rpx 16rpx;
  background-color: #fafafa;
  border-radius: 8rpx;
}

/* 幸运信息卡片 */
.lucky-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.lucky-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  background-color: #fafafa;
  border-radius: 16rpx;
}

.lucky-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.lucky-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.lucky-value {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
}

.lucky-values {
  display: flex;
  gap: 8rpx;
}

.lucky-number {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
  background-color: #fff;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}
