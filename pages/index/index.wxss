/* pages/index/index.wxss - 首页日历样式 */
/* cc-ui 简洁风格 */

.page-container {
  min-height: 100vh;
  background-color: #f8f8f8;
  display: flex;
  flex-direction: column;
}

/* 事件面板 */
.event-panel {
  background-color: #ffffff;
  border-top-left-radius: 24rpx;
  border-top-right-radius: 24rpx;
  padding: 24rpx;
  margin-top: -24rpx;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.event-panel.show {
  transform: translateY(0);
}

/* 拖拽指示条 */
.panel-drag-handle {
  width: 64rpx;
  height: 8rpx;
  background-color: #e0e0e0;
  border-radius: 4rpx;
  margin: 0 auto 16rpx;
}

/* 事件面板头部 */
.event-panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.event-date {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.event-actions {
  display: flex;
  gap: 20rpx;
}

.add-btn {
  font-size: 28rpx;
  color: #5677fc;
  padding: 8rpx 16rpx;
}

.close-btn {
  font-size: 28rpx;
  color: #999;
  padding: 8rpx 16rpx;
}

/* 事件列表 */
.event-list {
  padding: 16rpx 0;
  max-height: 400rpx;
}

/* 事件项容器 */
.event-item-wrapper {
  position: relative;
  overflow: hidden;
}

.event-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  transition: transform 0.3s ease;
  background-color: #fff;
}

.event-item.swiped {
  transform: translateX(-120rpx);
}

.event-item:last-child {
  border-bottom: none;
}

.event-color {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.event-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.event-title {
  font-size: 28rpx;
  color: #333;
}

.event-time {
  font-size: 24rpx;
  color: #999;
}

/* 删除按钮 */
.delete-btn {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 120rpx;
  background-color: #ff4d4f;
  color: #fff;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transform: translateX(100%);
  transition: transform 0.3s ease;
}

.event-item.swiped + .delete-btn {
  transform: translateX(0);
}

/* 无事件 */
.no-event {
  text-align: center;
  padding: 32rpx;
  color: #999;
  font-size: 28rpx;
}